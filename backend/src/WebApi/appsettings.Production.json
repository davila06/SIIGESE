{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "#{DB_CONNECTION_STRING}#",
    "Redis": "#{REDIS_CONNECTION_STRING}#",
    "AzureBlob": "#{AZURE_BLOB_CONNECTION_STRING}#"
  },
  "Jwt": {
    "Secret": "#{JWT_SECRET}#",
    "Issuer": "SiinadsegAPI",
    "Audience": "SiinadsegClient",
    "ExpirationHours": 8
  },
  "Cors": {
    "AllowedOrigins": [
      "https://gentle-dune-0a2edab0f.3.azurestaticapps.net",
      "https://green-beach-02a282f0f.3.azurestaticapps.net"
    ]
  },
  "FileUpload": {
    "Reclamos": {
      "MaxFileSizeInMB": 15,
      "AllowedExtensions": [".pdf", ".png", ".jpg", ".jpeg", ".doc", ".docx", ".xls", ".xlsx"],
      "UploadPath": "uploads/reclamos"
    }
  },
  "AzureBlobStorage": {
    "ContainerName": "reclamos-documentos",
    "ReclamosPrefix": "reclamos"
  },
  "Reports": {
    "AutomationEnabled": true,
    "PollIntervalMinutes": 120,
    "MorosidadRecipients": [],
    "MorosidadRecipientsCsv": ""
  },
  "AllowedHosts": "*"
}
